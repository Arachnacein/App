@page "/budget"

<PageTitle>@Localizer["Title"]</PageTitle>
<MudTabs Class="budget-tabs pa-2 ma-2" Elevation="0" Rounded="false" ApplyEffectsToContainer="false" TabPanelsClass="pa-4 pt-3" Centered="true">
    <MudTabPanel Text="@Localizer["Transactions"]" >
        <MudStack  AlignItems="AlignItems.End">
            <MudStack Row="true">
                <MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTransaction" Class="mr-auto">
                        @Localizer["AddTransaction"]
                    </MudButton>
                </MudStack>
                <MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddRecurringTransaction" Class="ml-auto">
                        @Localizer["AddRecurringTransaction"]
                    </MudButton>
                </MudStack>
                <MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" OnClick="AddIncome" Class="ml-auto mr-5">
                        @Localizer["AddIncome"]
                    </MudButton>
                </MudStack>
            </MudStack>
     
            <MudStack>
                <MudTooltip Placement="Placement.Left" ShowOnHover="true" Delay="150" Class="ma-1 mr-4 pa-2" RootStyle="width: 100%;">
                    <ChildContent>
                        <MudIcon Icon="@Icons.Material.Filled.Info" />
                    </ChildContent>
                    <TooltipContent> 
                        @if (UserSessionService == null || UserSessionService.UserId == Guid.Empty)
                        {
                            <MudText Typo="Typo.body2">@Localizer["MustSignIn"]</MudText>
                        }
                        else if (_patternViewModel == null || _patternViewModel.Id == 0)
                        {
                            <MudText Typo="Typo.body2">@Localizer["NoPattern"]</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@Localizer["PatternText"]: @_patternViewModel.Name</MudText>
                            <MudText Typo="Typo.body2">@Localizer["SavesText"]: @_patternViewModel.Value_Saves %</MudText>
                            <MudText Typo="Typo.body2">@Localizer["FeesText"]: @_patternViewModel.Value_Fees %</MudText>
                            <MudText Typo="Typo.body2">@Localizer["EntertainmentText"]: @_patternViewModel.Value_Entertainment %</MudText>
                        }
                    </TooltipContent>
                </MudTooltip>
            </MudStack>
        </MudStack>

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="ma-1 pa-1 mt-2">
            <MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowLeft" OnClick="PreviousMonth" Size="Size.Large"></MudIconButton>
            <MudText Typo="Typo.h6" Class="mx-2">@_currentDate.GetMonthName() @_currentDate.Year</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowRight" OnClick="NextMonth" Size="Size.Large"></MudIconButton>
        </MudStack>
        <MudStack AlignItems="AlignItems.Center" Class="mb-1">
            <MudText Typo="Typo.body1">@Localizer["MonthlyBudget"]: @($"{TotalIncome:F2}") zł</MudText>
        </MudStack>

        <MudGrid Class="mb-2 px-1" Spacing="2">
            <MudItem xs="12" md="4">
                <MudPaper Class="kpi-card kpi-card-saves pa-4 pb-0" Elevation="0">
                    <MudText Typo="Typo.overline" Color="Color.Success">@Localizer["Saves"]</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5" Color="Color.Success" Class="font-weight-bold mb-1">@($"{_patternValuesModel.ActualValueSaves:F2}") zł</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">/ @($"{_patternValuesModel.TotalValueSaves:F2}") zł</MudText>
                        </MudStack>
                        <MudTooltip Text="@Localizer["RecurringSum"]" Placement="Placement.Top">
                            <MudStack AlignItems="AlignItems.End" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Filled.Repeat" Size="Size.Small" Class="mud-text-secondary" />
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@($"{_patternValuesModel.RecurringValueSaves:F2}") zł</MudText>
                            </MudStack>
                        </MudTooltip>
                    </MudStack>
                    <MudProgressLinear Value="@_patternValuesModel.ActualValueSaves"
                                       Max="@(_patternValuesModel.TotalValueSaves == 0 ? 1 : _patternValuesModel.TotalValueSaves)"
                                       Color="Color.Success" Class="kpi-bottom-bar" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="kpi-card kpi-card-fees pa-4 pb-0" Elevation="0">
                    <MudText Typo="Typo.overline" Color="Color.Error">@Localizer["Fees"]</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5" Color="Color.Error" Class="font-weight-bold mb-1">@($"{_patternValuesModel.ActualValueFees:F2}") zł</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">/ @($"{_patternValuesModel.TotalValueFees:F2}") zł</MudText>
                        </MudStack>
                        <MudTooltip Text="@Localizer["RecurringSum"]" Placement="Placement.Top">
                            <MudStack AlignItems="AlignItems.End" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Filled.Repeat" Size="Size.Small" Class="mud-text-secondary" />
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@($"{_patternValuesModel.RecurringValueFees:F2}") zł</MudText>
                            </MudStack>
                        </MudTooltip>
                    </MudStack>
                    <MudProgressLinear Value="@_patternValuesModel.ActualValueFees"
                                       Max="@(_patternValuesModel.TotalValueFees == 0 ? 1 : _patternValuesModel.TotalValueFees)"
                                       Color="Color.Error" Class="kpi-bottom-bar" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="kpi-card kpi-card-entert pa-4 pb-0" Elevation="0">
                    <MudText Typo="Typo.overline" Color="Color.Info">@Localizer["Entertainment"]</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5" Color="Color.Info" Class="font-weight-bold mb-1">@($"{_patternValuesModel.ActualValueEntertainment:F2}") zł</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">/ @($"{_patternValuesModel.TotalValueEntertainment:F2}") zł</MudText>
                        </MudStack>
                        <MudTooltip Text="@Localizer["RecurringSum"]" Placement="Placement.Top">
                            <MudStack AlignItems="AlignItems.End" Spacing="0">
                                <MudIcon Icon="@Icons.Material.Filled.Repeat" Size="Size.Small" Class="mud-text-secondary" />
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@($"{_patternValuesModel.RecurringValueEntertainment:F2}") zł</MudText>
                            </MudStack>
                        </MudTooltip>
                    </MudStack>
                    <MudProgressLinear Value="@_patternValuesModel.ActualValueEntertainment"
                                       Max="@(_patternValuesModel.TotalValueEntertainment == 0 ? 1 : _patternValuesModel.TotalValueEntertainment)"
                                       Color="Color.Info" Class="kpi-bottom-bar" />
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudDropContainer T="TransactionViewModel"
                          Items="_transactions"
                          ItemsSelector="@((item,dropzone) => Enum.GetName(typeof(TransactionCategoryEnum), item.Category) == dropzone)"
                          ItemDropped="ItemUpdated"
                          Class="d-flex flex-wrap flex-grow-1">
            <ChildContent>
                <UI.Components.BudgetTransactionDropZone 
                                Title="@Localizer["Saves"]" Identifier="Saves"
                                ActualValue="_patternValuesModel.ActualValueSaves"
                                TotalValue="_patternValuesModel.TotalValueSaves"
                                TitleColor="Color.Success" Color="forestgreen"
                                IsLoading="_isLoadingTransactions"/>        
                <UI.Components.BudgetTransactionDropZone 
                                Title="@Localizer["Fees"]" Identifier="Fees"
                                ActualValue="_patternValuesModel.ActualValueFees"
                                TotalValue="_patternValuesModel.TotalValueFees"
                                TitleColor="Color.Error" Color="darkred" 
                                IsLoading="_isLoadingTransactions"/>            
                <UI.Components.BudgetTransactionDropZone 
                                Title="@Localizer["Entertainment"]" Identifier="Entertainment"
                                ActualValue="_patternValuesModel.ActualValueEntertainment"
                                TotalValue="_patternValuesModel.TotalValueEntertainment"
                                TitleColor="Color.Info" Color="dodgerblue" 
                                IsLoading="_isLoadingTransactions"/>
            </ChildContent>
            <ItemRenderer>
                <MudTooltip Placement="Placement.Bottom" ShowOnHover="true" Delay="150" Class="ma-4 pa-4" RootStyle="width: 100%;">
                    <ChildContent>
                        <MudPaper Elevation="0"
                                  Class="@($"transaction-card pa-2 my-2{GetBarClass(context)}")"
                                  Style="@GetBorderStyle(context)"
                                  @onclick="() => EditDeleteTransaction(context)">
                            <MudGrid Class="flex-nowrap">
                                @if (GlobalInfo.RecurringTheme == RecurringTransactionTheme.Icons)
                                {
                                    <MudItem xs="6" md="5" Class="text-align-center">
                                        <MudText Typo="Typo.body1">@context.Name</MudText>
                                    </MudItem>
                                    <MudItem xs="2" md="2" Class="d-flex align-center justify-center">
                                        @if (context.IsRecurring == true && context.IsApproved == false)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Repeat" Size="Size.Small" Class="mud-text-secondary" />
                                            <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="Size.Small" Class="mud-text-secondary" />
                                        }
                                        else if (context.IsRecurring == true && context.IsApproved == true)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Repeat" Size="Size.Small" Class="mud-text-secondary" />
                                        }
                                    </MudItem>
                                    <MudItem xs="4" md="2" Class="text-align-center">
                                        <MudText Typo="Typo.body1">@context.Price</MudText>
                                    </MudItem>
                                    <MudItem xs="0" md="3" Class="text-align-center hide-on-small date-column">
                                        <MudText Typo="Typo.body1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Style="vertical-align: middle; margin-right: 4px;" />
                                            @context.Date.FormatDM()
                                        </MudText>
                                    </MudItem>
                                }
                                else
                                {
                                    <MudItem xs="8" md="6" Class="text-align-center">
                                        <MudText Typo="Typo.body1">@context.Name</MudText>
                                    </MudItem>
                                    <MudItem xs="4" md="3" Class="text-align-center">
                                        <MudText Typo="Typo.body1">@context.Price</MudText>
                                    </MudItem>
                                    <MudItem xs="0" md="3" Class="text-align-center hide-on-small date-column">
                                        <MudText Typo="Typo.body1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Style="vertical-align: middle; margin-right: 4px;" />
                                            @context.Date.FormatDM()
                                        </MudText>
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudPaper>
                    </ChildContent>
                    <TooltipContent>
                        <MudText Typo="Typo.body2">@context.Date.FormatDMY()</MudText>
                        <MudText Typo="Typo.body2">@context.Description</MudText>
                    </TooltipContent>
                </MudTooltip>
            </ItemRenderer>
        </MudDropContainer>
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["Statistics"]"> 
        <UI.Components.StatisticsComponent />
    </MudTabPanel>
</MudTabs>