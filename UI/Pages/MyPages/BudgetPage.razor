@page "/budget"
@using UI.Models;
@using UI.Models.ViewModels

<PageTitle>@Localizer["Title"]</PageTitle>
<MudTabs Class="budget-tabs pa-2 ma-2" Elevation="0" Rounded="false" ApplyEffectsToContainer="false" PanelClass="pa-4 pt-3" Centered="true">
    <MudTabPanel Text="@Localizer["Transactions"]" >
        <MudStack  AlignItems="AlignItems.End">
            <MudStack Row="true">
                <MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddTransaction" Class="mr-auto">
                        @Localizer["AddTransaction"]
                    </MudButton>
                </MudStack>
                <MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddRecurringTransaction" Class="ml-auto">
                        @Localizer["AddRecurringTransaction"]
                    </MudButton>
                </MudStack>
                <MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" OnClick="AddIncome" Class="ml-auto mr-5">
                        @Localizer["AddIncome"]
                    </MudButton>
                </MudStack>
            </MudStack>
     
            <MudStack>
                <MudTooltip Placement="Placement.Left" ShowOnHover="true" Delay="150" Class="ma-1 mr-4 pa-2" RootStyle="width: 100%;">
                    <ChildContent>
                        <MudIcon Icon="@Icons.Material.Filled.Info" />
                    </ChildContent>
                    <TooltipContent> 
                        @if (UserSessionService == null || UserSessionService.UserId == Guid.Empty)
                        {
                            <MudText Typo="Typo.body2">@Localizer["MustSignIn"]</MudText>
                        }
                        else if (patternViewModel == null || patternViewModel.Id == 0)
                        {
                            <MudText Typo="Typo.body2">@Localizer["NoPattern"]</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@Localizer["PatternText"]: @patternViewModel.Name</MudText>
                            <MudText Typo="Typo.body2">@Localizer["SavesText"]: @patternViewModel.Value_Saves %</MudText>
                            <MudText Typo="Typo.body2">@Localizer["FeesText"]: @patternViewModel.Value_Fees %</MudText>
                            <MudText Typo="Typo.body2">@Localizer["EntertainmentText"]: @patternViewModel.Value_Entertainment %</MudText>
                        }
                    </TooltipContent>
                </MudTooltip>
            </MudStack>
        </MudStack>

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="ma-1 pa-1 mt-2">
            <MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowLeft" OnClick="PreviousMonth" Size="Size.Large"></MudIconButton>
            <MudText Typo="Typo.h6" Class="mx-2">@CurrentDate.GetMonthName() @CurrentDate.Year</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowRight" OnClick="NextMonth" Size="Size.Large"></MudIconButton>
        </MudStack>

        <MudGrid Class="mb-2 px-1" Spacing="2">
            <MudItem xs="12" md="4">
                <MudPaper Class="kpi-card kpi-card-saves pa-4 pb-0" Elevation="0">
                    <MudText Typo="Typo.overline" Color="Color.Success">@Localizer["Saves"]</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Success" Class="font-weight-bold mb-1">@($"{patternValuesModel.ActualValueSaves:F2}") zł</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">/ @($"{patternValuesModel.TotalValueSaves:F2}") zł</MudText>
                    <MudProgressLinear Value="@patternValuesModel.ActualValueSaves"
                                       Max="@(patternValuesModel.TotalValueSaves == 0 ? 1 : patternValuesModel.TotalValueSaves)"
                                       Color="Color.Success" Class="kpi-bottom-bar" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="kpi-card kpi-card-fees pa-4 pb-0" Elevation="0">
                    <MudText Typo="Typo.overline" Color="Color.Error">@Localizer["Fees"]</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Error" Class="font-weight-bold mb-1">@($"{patternValuesModel.ActualValueFees:F2}") zł</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">/ @($"{patternValuesModel.TotalValueFees:F2}") zł</MudText>
                    <MudProgressLinear Value="@patternValuesModel.ActualValueFees"
                                       Max="@(patternValuesModel.TotalValueFees == 0 ? 1 : patternValuesModel.TotalValueFees)"
                                       Color="Color.Error" Class="kpi-bottom-bar" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="kpi-card kpi-card-entert pa-4 pb-0" Elevation="0">
                    <MudText Typo="Typo.overline" Color="Color.Info">@Localizer["Entertainment"]</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Info" Class="font-weight-bold mb-1">@($"{patternValuesModel.ActualValueEntertainment:F2}") zł</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">/ @($"{patternValuesModel.TotalValueEntertainment:F2}") zł</MudText>
                    <MudProgressLinear Value="@patternValuesModel.ActualValueEntertainment"
                                       Max="@(patternValuesModel.TotalValueEntertainment == 0 ? 1 : patternValuesModel.TotalValueEntertainment)"
                                       Color="Color.Info" Class="kpi-bottom-bar" />
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudDropContainer T="TransactionViewModel"
                          Items="transactions"
                          ItemsSelector="@((item,dropzone) => Enum.GetName(typeof(TransactionCategoryEnum), item.Category) == dropzone)"
                          ItemDropped="ItemUpdated"
                          Class="d-flex flex-wrap flex-grow-1">
            <ChildContent>
                <UI.Components.BudgetTransactionDropZone 
                                Title="@Localizer["Saves"]" Identifier="Saves"
                                ActualValue="patternValuesModel.ActualValueSaves"
                                TotalValue="patternValuesModel.TotalValueSaves"
                                TitleColor="Color.Success" Color="forestgreen"
                                IsLoading="IsLoadingTransactions"/>        
                <UI.Components.BudgetTransactionDropZone 
                                Title="@Localizer["Fees"]" Identifier="Fees"
                                ActualValue="patternValuesModel.ActualValueFees"
                                TotalValue="patternValuesModel.TotalValueFees"
                                TitleColor="Color.Error" Color="darkred" 
                                IsLoading="IsLoadingTransactions"/>            
                <UI.Components.BudgetTransactionDropZone 
                                Title="@Localizer["Entertainment"]" Identifier="Entertainment"
                                ActualValue="patternValuesModel.ActualValueEntertainment"
                                TotalValue="patternValuesModel.TotalValueEntertainment"
                                TitleColor="Color.Info" Color="dodgerblue" 
                                IsLoading="IsLoadingTransactions"/>
            </ChildContent>
            <ItemRenderer>
                <MudTooltip Placement="Placement.Bottom" ShowOnHover="true" Delay="150" Class="ma-4 pa-4" RootStyle="width: 100%;">
                    <ChildContent>
                        <MudPaper Elevation="0" Class="transaction-card pa-2 my-2"
                                  Style="@((context.IsRecurring == true && context.IsApproved == true) ? "border: 1px solid #10B981 !important;" :
                                            (context.IsRecurring == true && context.IsApproved == false) ? "border: 1px dashed rgba(167,139,250,0.5) !important;" : null)"
                                  @onclick="() => EditDeleteTransaction(context)">
                            <MudGrid Class="flex-nowrap">
                                <MudItem xs="8" md="6" Class="text-align-center">
                                    <MudText Typo="Typo.body1">@context.Name</MudText>
                                </MudItem>
                                <MudItem xs="4" md="3" Class="text-align-center">
                                    <MudText Typo="Typo.body1">@context.Price</MudText>
                                </MudItem>       
                                <MudItem xs="0" md="3" Class="text-align-center hide-on-small date-column">
                                    <MudText Typo="Typo.body1">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Style="vertical-align: middle; margin-right: 4px;" />
                                        @context.Date.FormatDM()
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </ChildContent>
                    <TooltipContent>
                        <MudText Typo="Typo.body2">@context.Date.FormatDMY()</MudText>
                        <MudText Typo="Typo.body2">@context.Description</MudText>
                    </TooltipContent>
                </MudTooltip>
            </ItemRenderer>
        </MudDropContainer>
    </MudTabPanel>

    <MudTabPanel Text="@Localizer["Statistics"]"> 
        <UI.Components.StatisticsComponent />
    </MudTabPanel>
</MudTabs>