@page "/register"
@inject ISnackbar Snackbar

<PageTitle>@Localizer["RegisterTitle"]</PageTitle>
<div class="login-container">
    <MudPaper Class="glass-panel pa-6 d-flex flex-column align-items-center" Elevation="0" Style="width: min(400px, 95vw);">
        <MudText Typo="Typo.h5" Class="gradient-text mb-1" Align="Align.Center">◆ BudgetApp</MudText>
        <MudText Typo="Typo.h5" Class="mb-4" Align="Align.Center">@Localizer["SignUp"]</MudText>

        <MudForm Model="_registrationModel" @ref="_form" Validation="RegistrationModelValidator.ValidateValue()" ValidationDelay="0">
            <MudTextField @bind-Value="_registrationModel.FirstName" Label="@Localizer["FirstName"]"
                For="@(() => _registrationModel.FirstName)" Variant="Variant.Outlined" Class="ma-2 pa-1"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />

            <MudTextField @bind-Value="_registrationModel.LastName" Label="@Localizer["LastName"]"
                For="@(() => _registrationModel.LastName)" Variant="Variant.Outlined" Class="ma-2 pa-1"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />

            <MudTextField @bind-Value="_registrationModel.Username" Label="@Localizer["Username"]"
                For="@(() => _registrationModel.Username)" Variant="Variant.Outlined" Class="ma-2 pa-1"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Face" />

            <MudTextField @bind-Value="_registrationModel.Email" Label="@Localizer["Email"]"
                For="@(() => _registrationModel.Email)" Variant="Variant.Outlined" Class="ma-2 pa-1"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />

            <MudTextField @bind-Value="_registrationModel.Password" Label="@Localizer["Password"]" InputType="@_passwordInput"
                          For="@(() => _registrationModel.Password)" Variant="Variant.Outlined" Class="ma-2 pa-1"
                Adornment="Adornment.End" AdornmentIcon="@_passwordInputIcon" OnAdornmentClick="ShowPassword" />

            <MudTextField @bind-Value="_registrationModel.ConfirmPassword" Label="@Localizer["ConfirmPassword"]" InputType="@_passwordInput"
                          For="@(() => _registrationModel.ConfirmPassword)" Variant="Variant.Outlined" Class="ma-2 pa-1"
                Adornment="Adornment.End" AdornmentIcon="@_passwordInputIcon" OnAdornmentClick="ShowPassword" />

            <div class="g-recaptcha" data-sitekey="6LfCwL8qAAAAAKWlogobXgEEWcGjhE93gQFKtEXP"></div>

            <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ma-2 mt-4 px-6">@Localizer["SignUp"]</MudButton>
        </MudForm>
    </MudPaper>
</div>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>