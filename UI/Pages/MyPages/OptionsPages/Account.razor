@page "/options/account"
@using UI.Models;
@using UI.Models.ViewModels

<PageTitle>@Localizer["Title"]</PageTitle>
<UI.Components.OptionNavigationComponent />

@if (UserSessionService == null || UserSessionService.UserId == Guid.Empty)
{
    <MudPaper Class="ma-7 pa-7" Elevation="30">
        <MudText Typo="Typo.h6" Align="Align.Center">@Localizer["MustLogIn"]</MudText>
    </MudPaper>
}
else
{
    <MudPaper Class="ma-1 pa-4" Elevation="5">

        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Large" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.h5">@Localizer["Title"]</MudText>
        </MudStack>
        <MudDivider Class="mb-4" />

        <!-- Edytowalne dane -->
        <MudGrid Spacing="0">
            <MudItem xs="12" sm="4" Class="account-label-cell">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="account-field-label">@Localizer["LabelUserName"]</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" Class="account-value-cell">
                <MudText Typo="Typo.body1">@UserDetails.Username</MudText>
            </MudItem>
            <MudItem xs="12" sm="2" Class="account-action-cell">
                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                           OnClick="() => EditData(nameof(UserDetails.Username))">@Localizer["Edit"]</MudButton>
            </MudItem>
            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

            <MudItem xs="12" sm="4" Class="account-label-cell">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="account-field-label">@Localizer["LabelFirstName"]</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" Class="account-value-cell">
                <MudText Typo="Typo.body1">@UserDetails.FirstName</MudText>
            </MudItem>
            <MudItem xs="12" sm="2" Class="account-action-cell">
                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                           OnClick="() => EditData(nameof(UserDetails.FirstName))">@Localizer["Edit"]</MudButton>
            </MudItem>
            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

            <MudItem xs="12" sm="4" Class="account-label-cell">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="account-field-label">@Localizer["LabelLastName"]</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" Class="account-value-cell">
                <MudText Typo="Typo.body1">@UserDetails.LastName</MudText>
            </MudItem>
            <MudItem xs="12" sm="2" Class="account-action-cell">
                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                           OnClick="() => EditData(nameof(UserDetails.LastName))">@Localizer["Edit"]</MudButton>
            </MudItem>
            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

            <MudItem xs="12" sm="4" Class="account-label-cell">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="account-field-label">@Localizer["LabelEmail"]</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" Class="account-value-cell">
                <MudText Typo="Typo.body1">@UserDetails.Email</MudText>
            </MudItem>
            <MudItem xs="12" sm="2" Class="account-action-cell">
                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                           OnClick="() => EditData(nameof(UserDetails.Email))">@Localizer["Edit"]</MudButton>
            </MudItem>

            @if (!UserSessionService.EmailVerified)
            {
                <MudItem xs="12" Class="mt-2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                        <MudText Typo="Typo.body2" Color="Color.Warning">@Localizer["LabelVerifyEmail"]</MudText>
                        <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                   OnClick="VerifyEmail">@Localizer["Verify"]</MudButton>
                    </MudStack>
                </MudItem>
            }
        </MudGrid>

        <MudDivider Class="my-5" />

        <!-- Dane tylko do odczytu -->
        <MudGrid Spacing="0">
            <MudItem xs="12" sm="4" Class="account-label-cell">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="account-field-label">Roles</MudText>
            </MudItem>
            <MudItem xs="12" sm="8" Class="account-value-cell">
                <MudText Typo="Typo.body1">@string.Join(", ", UserDetails.Roles)</MudText>
            </MudItem>
            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

            <MudItem xs="12" sm="4" Class="account-label-cell">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="account-field-label">@Localizer["AccountCreated"]</MudText>
            </MudItem>
            <MudItem xs="12" sm="8" Class="account-value-cell">
                <MudText Typo="Typo.body1">@UserDetails.AccountCreatedDate?.ToString("dd-MM-yyyy HH:mm")</MudText>
            </MudItem>
            <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

            <MudItem xs="12" sm="4" Class="account-label-cell">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="account-field-label">@Localizer["SessionExpirations"]</MudText>
            </MudItem>
            <MudItem xs="12" sm="8" Class="account-value-cell">
                <MudText Typo="Typo.body1">@UserDetails.SessionExpiryDate.ToString("dd-MM-yyyy HH:mm")</MudText>
            </MudItem>
        </MudGrid>

    </MudPaper>
}
