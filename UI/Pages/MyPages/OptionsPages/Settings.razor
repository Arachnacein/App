@page "/options/settings"
@inject GlobalInfoClass _globalClass;
@inject NavigationManager Navigation
@inject IStringLocalizer<Settings> Localizer

<PageTitle> @Localizer["PageTitle"] </PageTitle>
<UI.Components.OptionNavigationComponent />
<MudPaper Class="ma-1 pa-4" Elevation="5">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="pa-2 ma-2">@Localizer["Header"]</MudText>
    <MudDivider Class="mb-6"/>
    <MudStack AlignItems="AlignItems.Center" Class="mb-6">
        <MudSwitch @bind-Value="_globalClass.IsDarkMode" Color="Color.Primary"
                   T="bool" Label="Ciemny motyw" @onclick="Refresh"/>
    </MudStack>
</MudPaper>

@code{
     private void Refresh() => Navigation.NavigateTo("/options/settings");
}