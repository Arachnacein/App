<MudDialog Class="pa-4">
    <DialogContent>
        <MudForm @ref="@_form" Model="@_model" Validation="RecurringTransactionValidator.ValidateValue()" ValidationDelay="0">
            <MudStack>
                <MudTextField @bind-Value="_model.Name" For="@(() => _model.Name)"  Label="@Localizer["RecurringTransaction"]" Required="true" Margin="Margin.Normal" />
                <MudTextField @bind-Value="_model.Description" For="@(() => _model.Description)" Label="@Localizer["Description"]" Required="true" Margin="Margin.Normal" />
                <MudStack Row="true">
                    <MudDatePicker @bind-Date="_model.StartDate" For="@(() => _model.StartDate)" Label="@Localizer["StartDate"]" Required="true" Margin="Margin.Normal" />
                    <MudDatePicker @bind-Date="_model.EndDate" For="@(() => _model.EndDate)" Label="@Localizer["EndDate"]" Required="true" Margin="Margin.Normal" />
                </MudStack>
                <MudTextField @bind-Value="_model.Amount" For="@(() => _model.Amount)" Label="@Localizer["Amount"]" Required="true" Margin="Margin.Normal" />
                <MudStack AlignItems="AlignItems.Center">
                    <MudRadioGroup @bind-Value="_model.TransactionType" Required="true">
                        <MudRadio Value="TransactionTypeEnum.Expense" Color="Color.Secondary">@Localizer["Expense"]</MudRadio>
                        <MudRadio Value="TransactionTypeEnum.Income" Color="Color.Tertiary" Disabled="true">@Localizer["Income"]</MudRadio>
                    </MudRadioGroup>
                </MudStack>
            </MudStack>
            <MudText Class="mt-3">@Localizer["Repeat"]:</MudText>
            <MudStack Row="true">
                <MudGrid>
                    <MudItem xs="4">
                        <MudNumericField @bind-Value="_model.Interval" For="@(() => _model.Interval)" T="int" Required="true"
                            Margin="Margin.Normal" FullWidth="true"/>
                    </MudItem>
                    <MudItem xs="8">
                        <MudSelect @bind-Value="_model.Frequency" T="FrequencyEnum" Required="true" Margin="Margin.Normal" FullWidth="true">
                            <MudSelectItem Value="FrequencyEnum.Daily">@Localizer["Day"]</MudSelectItem>
                            <MudSelectItem Value="FrequencyEnum.Weekly">@Localizer["Week"]</MudSelectItem>
                            <MudSelectItem Value="FrequencyEnum.Monthly">@Localizer["Month"]</MudSelectItem>
                            <MudSelectItem Value="FrequencyEnum.Yearly">@Localizer["Year"]</MudSelectItem>
                            <MudSelectItem Value="FrequencyEnum.Custom">@Localizer["Custom"]</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudStack>

            @switch (_model.Frequency)
            {
                case FrequencyEnum.Monthly:
                    <DateRangeTextComponent Frequency="@_model.Frequency" Interval=@_model.Interval StartDate="@_model.StartDate" EndDate="@_model.EndDate" />
                    break;
                case FrequencyEnum.Weekly:
                    <DateRangeTextComponent Frequency="@_model.Frequency" Interval=@_model.Interval StartDate="@_model.StartDate" EndDate="@_model.EndDate" />
                    break;
                case FrequencyEnum.Yearly:
                    <DateRangeTextComponent Frequency="@_model.Frequency" Interval=@_model.Interval StartDate="@_model.StartDate" EndDate="@_model.EndDate" />
                    break;
                case FrequencyEnum.Daily:
                    <DateRangeTextComponent Frequency="@_model.Frequency" Interval=@_model.Interval StartDate="@_model.StartDate" EndDate="@_model.EndDate"/>
                    break;
                case FrequencyEnum.Custom:
                    <MudButton OnClick="OpenCustomDialog" Class="ma-2 pa-2" Color="Color.Primary" Variant="Variant.Outlined">@Localizer["Custom"]</MudButton>
                    break;
            }
        </MudForm>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Secondary">@Localizer["Cancel"]</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary">@Localizer["Submit"]</MudButton>
    </DialogActions>
</MudDialog>