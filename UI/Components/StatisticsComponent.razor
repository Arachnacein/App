@if (UserSessionService == null || UserSessionService.UserId == Guid.Empty)
{
    <MudPaper Class="ma-7 pa-7" Elevation="30">
                <MudText Typo="Typo.h6" Align="Align.Center">@Localizer["MustLogIn"]</MudText>
    </MudPaper>
}
else
{
    <MudGrid Spacing="2" Class="mb-4 px-2">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="kpi-card kpi-card-saves pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Color="Color.Success">@Localizer["TotalSaves"]</MudText>
                <MudText Typo="Typo.h5" Color="Color.Success" Class="font-weight-bold">@TotalSaves</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="kpi-card kpi-card-fees pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Color="Color.Secondary">@Localizer["TotalExpenses"]</MudText>
                <MudText Typo="Typo.h5" Color="Color.Secondary" Class="font-weight-bold">@TotalExpenses</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="kpi-card kpi-card-saves pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Color="Color.Success">@Localizer["AverageSaves"]</MudText>
                <MudText Typo="Typo.h5" Color="Color.Success" Class="font-weight-bold">@AverageSaves</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="kpi-card kpi-card-fees pa-4" Elevation="0">
                <MudText Typo="Typo.overline" Color="Color.Secondary">@Localizer["AverageExpenses"]</MudText>
                <MudText Typo="Typo.h5" Color="Color.Secondary" Class="font-weight-bold">@AverageExpenses</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudPaper Class="kpi-card kpi-card-saves pa-3" Elevation="0">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@Localizer["Total3MonthsSaves"]</MudText>
                <MudText Typo="Typo.h6" Color="Color.Success">@Total3MonthsSaves</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudPaper Class="kpi-card kpi-card-fees pa-3" Elevation="0">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@Localizer["Total3MonthsExpenses"]</MudText>
                <MudText Typo="Typo.h6" Color="Color.Secondary">@Total3MonthsExpenses</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="ma-2" Style="flex-wrap: wrap;">
        <MudPaper Class="kpi-card pa-2" Elevation="0" Style="width: min(28%, 300px); min-width: 200px;">
            <MudChart ChartType="ChartType.Pie" InputData="@CategoriesDistribution.ToArray()"
                      InputLabels="@CategoriesDistribution.GetPropertyNames(Localizer)"
                      Width="100%" Height="280px" LegendPosition="Position.Bottom" Class="mt-2" />
        </MudPaper>

        <MudPaper Class="kpi-card pa-2" Elevation="0" Style="flex: 1; min-width: 300px;">
            <MudChart ChartType="ChartType.StackedBar" ChartSeries="@Series" XAxisLabels="@XaxisLabels"
                      Width="100%" Height="300px" LegendPosition="Position.Right" Class="pa-2"/>
        </MudPaper>
    </MudStack>

}